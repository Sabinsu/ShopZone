# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/shopzone

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRE=30d
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
CLIENT_URL=https://shop-zone-pearl.vercel.app

# ── Cloudinary (for image uploads — optional, falls back to local /uploads) ──
# Get free account at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Payment (Stripe or local) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key

# ── AI (Claude) ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key
