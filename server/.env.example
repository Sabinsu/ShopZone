# ── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas ────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/shopzone?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_min_32_chars_here
JWT_EXPIRE=30d

# ── CORS ─────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Google OAuth ──────────────────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# ── Cloudinary (image uploads) ───────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── SMTP (Nodemailer) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_EMAIL=noreply@shopzone.com
FROM_NAME=ShopZone

# ── Stripe (optional) ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxx

# ── Anthropic AI (optional chatbot) ─────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
